---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}
const {
  title = 'json2ashru — Stop paying LLMs for JSON punctuation',
  description = 'JSON wastes 60–80% of LLM output tokens on brackets, quotes, and repeated keys. ASHRU is a pipe-delimited extraction format that drops the cost. Built on Pāṇini\'s 6 kāraka case roles — 2,500 years old, public domain.',
  canonical = 'https://json2ashru.com',
  ogImage = '/og-default.svg',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
