---
---
<section id="streaming-demo" class="pt-2 pb-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-xs uppercase tracking-[0.2em] muted font-semibold mb-3 text-center">Watch the cost in real time</div>
    <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-3 text-center">
      Same fact. Two formats. <span class="gradient-text">Different bills.</span>
    </h2>
    <p class="text-center muted text-sm mb-10 max-w-2xl mx-auto">
      An LLM extracting 8 kāraka facts. Token counters tick at the published Gemini Flash output rate (~250 tok/s). Press play.
    </p>

    <div class="grid md:grid-cols-2 gap-4">
      <!-- JSON terminal -->
      <div class="term-window">
        <div class="term-bar">
          <span class="term-dot" style="background:#ff5f57"></span>
          <span class="term-dot" style="background:#febc2e"></span>
          <span class="term-dot" style="background:#28c840"></span>
          <span class="ml-3 text-xs muted font-mono">json — gemini-flash output</span>
          <span class="ml-auto text-xs font-mono"><span id="json-tok-counter" class="text-flame-300">0</span><span class="muted"> tokens</span></span>
        </div>
        <div class="term-body" id="json-stream"></div>
      </div>

      <!-- ASHRU terminal -->
      <div class="term-window" style="border-color: rgba(139, 92, 246, 0.3); box-shadow: 0 0 80px rgba(139,92,246,0.18);">
        <div class="term-bar" style="background: rgba(139,92,246,0.04);">
          <span class="term-dot" style="background:#ff5f57"></span>
          <span class="term-dot" style="background:#febc2e"></span>
          <span class="term-dot" style="background:#28c840"></span>
          <span class="ml-3 text-xs muted font-mono">ashru — gemini-flash output</span>
          <span class="ml-auto text-xs font-mono"><span id="ashru-tok-counter" class="text-mint-400">0</span><span class="muted"> tokens</span></span>
        </div>
        <div class="term-body" id="ashru-stream"></div>
      </div>
    </div>

    <div class="flex items-center justify-center gap-4 mt-6">
      <button id="stream-replay" class="px-4 py-2 rounded-lg border border-white/10 hover:border-accent-500/40 hover:bg-white/5 text-ink-100 font-mono text-xs">
        ↻ replay
      </button>
      <div class="text-xs muted font-mono">
        ASHRU finishes <span id="speed-ratio" class="text-mint-400 font-bold">3.4×</span> faster · saves
        <span id="cost-saved" class="text-mint-400 font-bold">$—</span> per 1M docs
      </div>
    </div>

    <div class="mt-6 text-center text-xs muted">
      Real numbers from <code class="text-accent-300 bg-black/40 px-2 py-0.5 rounded font-mono">benchmarks/run_benchmark.py --records 1000</code> with <code class="text-accent-300 bg-black/40 px-2 py-0.5 rounded font-mono">tiktoken cl100k_base</code>: ASHRU = 0.29× JSON tokens.
    </div>
  </div>
</section>

<script type="module">
  // 8 sample kāraka facts (real ones). Numbers grounded in tiktoken benchmark.
  const facts = [
    {verb:"buy",      karta:"Suman",   karma:"Tesla",      karana:"$60000", apadana:"John",   adhikarana:"SF"},
    {verb:"hire",     karta:"Acme",    karma:"Madhuri",    karana:"$220k",  apadana:"",       adhikarana:"NYC"},
    {verb:"deploy",   karta:"engineer",karma:"api-service",karana:"k8s",    apadana:"staging",adhikarana:"us-central1"},
    {verb:"send",     karta:"Maya",    karma:"wire",       karana:"swift",  apadana:"Chase",  adhikarana:"London"},
    {verb:"diagnose", karta:"Dr Patel",karma:"patient",    karana:"MRI",    apadana:"",       adhikarana:"Boston"},
    {verb:"schedule", karta:"PM",      karma:"release-1.2",karana:"Linear", apadana:"",       adhikarana:"Q3"},
    {verb:"publish",  karta:"author",  karma:"spec-v1",    karana:"github", apadana:"",       adhikarana:""},
    {verb:"transfer", karta:"broker",  karma:"100AAPL",    karana:"NYSE",   apadana:"fund_a", adhikarana:"fund_b"},
  ];

  function jsonDoc(fs) {
    const obj = {verbs: fs.map(f => ({
      verb_lemma: f.verb, "kartā": f.karta, karma: f.karma, "karaṇa": f.karana,
      "apādāna": f.apadana, "adhikaraṇa": f.adhikarana, tense: "past", is_negated: false
    }))};
    return JSON.stringify(obj, null, 2);
  }
  function ashruDoc(fs) {
    return "ASHRU/1\n" + fs.map(f =>
      `V|${f.verb}|${f.karta}|${f.karma}|${f.karana}||${f.apadana}|${f.adhikarana}|p|0|`
    ).join("\n");
  }
  // Approx tokens (chars/4 — close enough for a visual demo; real numbers come from tiktoken)
  const approxTokens = (s) => Math.max(1, Math.round(s.length / 4));

  const jsonText = jsonDoc(facts);
  const ashruText = ashruDoc(facts);
  const jsonTotal = approxTokens(jsonText);
  const ashruTotal = approxTokens(ashruText);
  const ratio = (jsonTotal / ashruTotal).toFixed(1);
  document.getElementById("speed-ratio").textContent = ratio + "×";

  // Cost-per-1M-docs at gemini-flash output rate ($2.50 / 1M output tokens)
  const PRICE = 2.50;
  const factor = 1_000_000; // per 1M docs
  const jsonCost = (jsonTotal * PRICE / 1_000_000) * factor;
  const ashruCost = (ashruTotal * PRICE / 1_000_000) * factor;
  document.getElementById("cost-saved").textContent = "$" + (jsonCost - ashruCost).toLocaleString('en-US', {maximumFractionDigits: 0});

  // Stream both at the SAME bytes-per-tick rate. ASHRU finishes first because it's smaller.
  const TICK_MS = 28;          // ~36 ticks/sec
  const CHARS_PER_TICK = 6;    // bytes streamed per tick (same for both — fairness)

  let timer = null;

  function streamInto(elId, counterId, fullText, totalTokens, color) {
    const el = document.getElementById(elId);
    const counter = document.getElementById(counterId);
    el.innerHTML = "";
    let i = 0;
    let tokens = 0;
    const span = document.createElement("span");
    span.style.color = "#cbd5e1";
    span.style.whiteSpace = "pre-wrap";
    el.appendChild(span);
    const cursor = document.createElement("span");
    cursor.className = "term-cursor";
    el.appendChild(cursor);

    return new Promise((resolve) => {
      const id = setInterval(() => {
        if (i >= fullText.length) {
          cursor.style.display = "none";
          clearInterval(id);
          resolve();
          return;
        }
        const next = Math.min(fullText.length, i + CHARS_PER_TICK);
        const chunk = fullText.slice(i, next);
        span.appendChild(document.createTextNode(chunk));
        i = next;
        tokens = approxTokens(fullText.slice(0, i));
        counter.textContent = tokens.toLocaleString();
        // Auto-scroll within the fixed-height terminal body
        el.scrollTop = el.scrollHeight;
      }, TICK_MS);
    });
  }

  async function run() {
    if (timer) return;
    timer = true;
    // Reset counters
    document.getElementById("json-tok-counter").textContent = "0";
    document.getElementById("ashru-tok-counter").textContent = "0";
    // Run both in parallel — same bytes-per-tick, ASHRU finishes first because shorter
    await Promise.all([
      streamInto("json-stream",  "json-tok-counter",  jsonText,  jsonTotal),
      streamInto("ashru-stream", "ashru-tok-counter", ashruText, ashruTotal),
    ]);
    timer = null;
  }

  document.getElementById("stream-replay").addEventListener("click", run);

  // Auto-run when the section enters the viewport
  const obs = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) {
      run();
      obs.disconnect();
    }
  }, {threshold: 0.4});
  obs.observe(document.getElementById("streaming-demo"));
</script>
