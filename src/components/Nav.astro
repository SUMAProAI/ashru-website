---
interface Props { current?: 'home' | 'spec' | 'github' }
const { current = 'home' } = Astro.props;
---
<nav class="sticky top-0 z-50 glass-strong">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-baseline gap-2">
      <span class="text-xl font-extrabold tracking-tight gradient-text">ASHRU</span>
      <span class="text-[0.65rem] font-mono px-1.5 py-0.5 rounded bg-mint-500/10 text-mint-400 border border-mint-500/20">v1.0.1</span>
    </a>
    <div class="flex items-center gap-6 text-sm">
      <a href="#format" class="text-ink-300 hover:text-white transition-colors">Format</a>
      <a href="#math" class="text-ink-300 hover:text-white transition-colors">The Math</a>
      <a href="#converter" class="text-ink-300 hover:text-white transition-colors">Converter</a>
      <a
        href="https://github.com/ashru-format/ashru-format"
        class="px-3 py-1.5 rounded-md border border-white/10 hover:border-accent-500 hover:bg-white/5 transition-all"
      >
        GitHub →
      </a>
    </div>
  </div>
</nav>
