---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import DropInChange from '../components/DropInChange.astro';
import WhatIsAshru from '../components/WhatIsAshru.astro';
import Architecture from '../components/Architecture.astro';
import Etymology from '../components/Etymology.astro';
import BatchExtraction from '../components/BatchExtraction.astro';
import MathTable from '../components/MathTable.astro';
import Calculator from '../components/Calculator.astro';
import Converter from '../components/Converter.astro';
import Ecosystem from '../components/Ecosystem.astro';
import Vision from '../components/Vision.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="ASHRU — Atomic Semantic Hyper-Relational Unit · The semantic transport layer for AI"
  description="JSON was designed for humans writing APIs. ASHRU is designed for machines generating semantics. A pipe-delimited extraction format built on Pāṇini's 6 kāraka case roles. Public domain spec, MIT parsers."
  canonical="https://json2ashru.com"
>
  <Nav />
  <main>
    <Hero />
    <Manifesto />
    <DropInChange />
    <WhatIsAshru />
    <Architecture />
    <Etymology />
    <BatchExtraction />
    <MathTable />
    <Calculator />
    <Converter />
    <Ecosystem />
    <Vision />
    <FAQ />
  </main>
  <Footer />
</Layout>
